# Copy this file to .env and fill in all values.
# Never commit .env to version control.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://leadsifter:leadsifter_dev@localhost:5432/leadsifter

# --- AI Provider ---
# Set one of these. Groq takes priority when GROQ_API_KEY is set.
# Groq (free tier available): https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL_PARSE=llama-3.3-70b-versatile
# OpenAI fallback:
OPENAI_API_KEY=sk-...
OPENAI_MODEL_PARSE=gpt-4o-mini
OPENAI_MODEL_CONVO=gpt-4o-mini

# --- Meta / WhatsApp ---
META_VERIFY_TOKEN=<your_meta_verify_token>

# --- Credential Encryption ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<fernet_key>

# --- Internal Service Auth ---
# Shared secret between FastAPI and n8n. Use a strong random value in production.
N8N_INTERNAL_KEY=<strong_random_secret>

# --- Admin API Auth ---
# Protects the broker provisioning endpoint.
ADMIN_API_KEY=<strong_random_secret>

# --- n8n Integration ---
# Use http://n8n:5678 when running in Docker Compose, http://localhost:5678 for local dev.
N8N_WEBHOOK_BASE=http://localhost:5678

# --- SendGrid ---
# ECDSA public key for webhook signature verification (optional, leave empty to skip).
SENDGRID_WEBHOOK_SECRET=

# --- App ---
DEBUG=false
LOG_LEVEL=INFO
